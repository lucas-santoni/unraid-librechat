#!/usr/bin/env bash
# generate-secret hex|base64 BYTES
set -euo pipefail
fmt="${1:?hex|base64 required}"
bytes="${2:?byte count required}"
case "${fmt}" in
  hex)    openssl rand -hex "${bytes}" ;;
  base64) openssl rand -base64 "${bytes}" | tr -d '\n' ;;
  *)      echo "generate-secret: unknown format ${fmt}" >&2; exit 1 ;;
esac
